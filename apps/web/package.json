{
  "name": "@limbus/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:static": "node scripts/prepare-static-assets.mjs",
    "dev": "pnpm prepare:static && vite",
    "build": "pnpm --filter @limbus/core build && pnpm prepare:static && tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@limbus/core": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
